# Gateway
GATEWAY_PORT=9093
GATEWAY_BUILD_TAGS=debug
SYSTEM_LOG_LEVEL=0
SYSTEM_ACCESS_TOKENS=replace-with-token:bans,reports,metrics

# Postgres (compose service "postgres"; DB_USER must stay pguser — db/init.sql)
DB_HOST=postgres
DB_PORT=5432
DB_USER=pguser
DB_PASSWORD=pgpassword
DB_NAME=gatewaydb
POSTGRES_PORT=5434

# tonutils-storage daemon
TONUTILS_STORAGE_VERSION=v1.5.1
TON_STORAGE_LOGIN=uClient
TON_STORAGE_PASSWORD=change-me-storage-api
TONUTILS_STORAGE_API_PORT=13475
TONUTILS_STORAGE_UDP_PORT=47432
# Public IPv4 or hostname for overlay DHT seeding (required behind NAT / empty auto-detect)
TONUTILS_STORAGE_EXTERNAL_IP=

# Metrics (optional)
NAMESPACE=ton-storage
SERVER_SUBSYSTEM=mtpo-server
WORKERS_SUBSYSTEM=mtpo-workers
DB_SUBSYSTEM=mtpo-db

# Remote TON Storage cache (optional)
REMOTE_TON_STORAGE_CACHE_MAX_ENTRIES=1000
